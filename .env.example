HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
API_BASE_URL=/api
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000
# Comma-separated list of allowed CORS origins. No wildcard "*" — list
# every origin the frontend is actually served from (default Vite port
# 5173, plus 3000 if you run the dev server with --port 3000).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Secure=True (the default) requires HTTPS for the refresh cookie. Local
# dev over plain http://localhost must explicitly set this to false, or
# the browser will silently drop the cookie and /refresh will fail.
COOKIE_SECURE=false
DATABASE_URL=sqlite:///./app/data/app.db
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=devpassword123
