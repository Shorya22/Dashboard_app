HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
API_BASE_URL=/api
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
DATABASE_URL=sqlite:///./app/data/app.db
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=devpassword123

# Docker Compose / Cloudflare tunnel (see docker-compose.yml comments and
# DOCKER.md for full instructions).
# Leave blank to use the zero-setup "quick tunnel" (random
# *.trycloudflare.com URL printed in `docker compose logs cloudflared`,
# changes every restart). To get a STABLE URL instead: Cloudflare Zero
# Trust dashboard -> Networks -> Tunnels -> Create a tunnel -> Docker
# connector -> copy the token here.
CLOUDFLARE_TUNNEL_TOKEN=
# Which cloudflared mode docker-compose.yml runs: "quick" (default, zero
# setup, random URL) or "named" (stable URL, requires the token above).
COMPOSE_PROFILES=quick
